egat:
  mem_per_cpu: 1000
  method: ml_rxn_prop
  model: egat_rgd1
  n_cpus: 1
initialize:
  enumeration:
    bonds to break: 2
    bonds to form: 2
    enumerate: true
    enumeration filters:
      discard strained rings: false
      formal charge: 2.0
      lewis score: 0.0
    mode: concerted
    reactive atoms:
    - 0
    - 1
    - 2
    - 3
  initial species: OCC=O
  job manager:
    container: docker
    max_active_jobs: 6
    scheduler: local
  output: depth1.pkl
ll_path:
  conformers:
    charge: 0
    energy_window: 6.0
    lot: gfn
    max_runtime: 01:00:00
    mem_per_cpu: 1000
    n_cpus: 2
    n_unpaired_electrons: 0
    software: crest
  gsm:
    bias_lot: uff
    charge: 0
    gsm_lot: xtb
    joint_opt: dual
    max_gsm_nodes: 30
    max_runtime: 01:00:00
    mem_per_cpu: 1000
    multiplicity: 1
    n_conf: 3
    n_cpus: 2
    software: pysisyphus
  method: init_rxn_path
  pre_process_filtering:
    property: barrier
    source: egat_rgd1
    threshold: 100.0
ll_refine:
  initial_geom:
    product:
      label: conf_gen
      lot: gfn
      software: crest
    reactant:
      label: conf_gen
      lot: gfn
      software: crest
    transition_state:
      label: ts_guess
      lot: xtb
      software: pysisyphus
  irc_val:
    conv_thresh: gau
    lot: xtb
    max_cycles: 300
    n_cpus: 2
    software: pysisyphus
  method: refine_rxn_path
  rp_opt:
    hessian_recalc: 3
    lot: xtb
    max_cycles: 300
    n_cpus: 2
    software: pysisyphus
  ts_opt:
    conv_thresh: gau
    hessian_recalc: 3
    lot: xtb
    max_cycles: 300
    n_cpus: 2
    software: pysisyphus
stages:
- egat
- ll_path
- ll_refine

