      lot: xtb
      software: pysisyphus
    reactant:
      label: rp_opt
      lot: xtb
      software: pysisyphus
    transition_state:
      label: ts_opt
      lot: xtb
      software: pysisyphus
  irc_val:
    charge: 0
    lot: PBE D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
  method: refine_rxn_path
  rp_opt:
    charge: 0
    hessian_recalc: 3
    lot: PBE D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
  ts_opt:
    charge: 0
    hessian_recalc: 3
    lot: PBE D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
hl_refine2:
  initial_geom:
    product:
      label: rp_opt
      lot: PBE D3BJ def2-SVP
      software: orca
    reactant:
      label: rp_opt
      lot: PBE D3BJ def2-SVP
      software: orca
    transition_state:
      label: ts_opt
      lot: PBE D3BJ def2-SVP
      software: orca
  irc_val:
    charge: 0
    lot: PBE0 D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
  method: refine_rxn_path
  rp_opt:
    charge: 0
    hessian_recalc: 3
    lot: PBE0 D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
  ts_opt:
    charge: 0
    hessian_recalc: 3
    lot: PBE0 D3BJ def2-SVP
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: orca
initialize:
  enumeration:
    mode: concerted
    n_break: 2
    n_form: 2
    post_enum_filters:
      formal_charge: 2.0
      lewis_score: 0.0
      ring_filter: false
    react_atoms:
    - 0
    - 1
    - 2
    - 3
  initial_structure:
    mode: species
    source: '[O:0]=[C:1]([C:2]([O:3][H:7])([H:5])[H:6])[H:4]'
    type: smiles
  job_manager:
    container: apptainer
    max_active_jobs: 100
    queue: long
    scheduler: sge
  output: HAA_depth1.pkl
  status: STATUS.json
  verbose: true
ll_path:
  conf_gen:
    charge: 0
    lot: gfn2
    mem_per_cpu: 8000
    n_cpus: 4
    n_unpaired_electrons: 0
    software: crest
  method: init_rxn_path
  ts_guess:
    bias_lot: uff
    charge: 0
    gsm_lot: xtb
    joint_opt: dual
    mem_per_cpu: 8000
    multiplicity: 1
    n_conf: 3
    n_cpus: 4
    software: pysisyphus
ll_refine:
  initial_geom:
    product:
      label: conf_gen
      lot: gfn2
      software: crest
    reactant:
      label: conf_gen
      lot: gfn2
      software: crest
    transition_state:
      label: ts_guess
      lot: xtb
      software: pysisyphus
  irc_val:
    charge: 0
    conv_thresh: gau
    lot: xtb
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: pysisyphus
  method: refine_rxn_path
  rp_opt:
    charge: 0
    hessian_recalc: 3
    lot: xtb
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: pysisyphus
  ts_opt:
    charge: 0
    conv_thresh: gau
    hessian_recalc: 3
    lot: xtb
    max_cycles: 100
    mem_per_cpu: 8000
    multiplicity: 1
    n_cpus: 4
    software: pysisyphus
stages:
- egat
- ll_path
- ll_refine
- hl_refine
- hl_refine2

