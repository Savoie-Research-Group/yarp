Bootstrap: docker
From: debian:bookworm-slim

%files
    # Copy the ORCA tarball from your host machine into the container's /opt directory
    orca_6_0_1_linux_x86-64_shared_openmpi416.tar.xz /opt/orca_installer.tar.xz

%environment
    # Set locale
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

    # Expose the conda environment binaries/libraries and ORCA directly to the system paths
    export PATH="/opt/env/bin:/opt/orca:${PATH}"
    export LD_LIBRARY_PATH="/opt/env/lib:/opt/orca"

    # Prevent OpenMPI warnings regarding memory/network architectures
    export OMPI_MCA_btl_vader_single_copy_mechanism=none
    export OMPI_MCA_rmaps_base_oversubscribe=1
    export OMPI_MCA_btl="^openib"

%post
    # Prevent interactive prompts during apt installations
    export DEBIAN_FRONTEND=noninteractive

    # Install essential dependencies
    apt-get update -q
    apt-get install -q -y --no-install-recommends \
        curl \
        bzip2 \
        ca-certificates \
        ssh \
        tar \
        xz-utils
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install Micromamba natively for environment management
    cd /tmp
    curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest | tar -xvj bin/micromamba
    mv bin/micromamba /usr/local/bin/micromamba
    rm -rf /tmp/bin

    # Create a micromamba environment containing exactly OpenMPI 4.1.6, xTB, and CREST
    # We install this into /opt/env instead of a user's home directory
    micromamba create -y -p /opt/env -c conda-forge openmpi=4.1.6 xtb crest
    micromamba clean --all --yes

    # Extract the ORCA tarball we copied in the %files section into /opt/orca
    mkdir -p /opt/orca
    tar -xf /opt/orca_installer.tar.xz -C /opt/orca --strip-components=1
    
    # Clean up the installer
    rm /opt/orca_installer.tar.xz

%runscript
    # This acts like the CMD in Docker. If you just 'apptainer run' the image, it opens bash.
    exec /bin/bash "$@"