egat:
  mem_per_cpu: 1000
  method: ml_rxn_prop
  model: egat_rgd1
  n_cpus: 1
initialize:
  enumeration:
    mode: concerted
    n_break: 2
    n_form: 2
    post_enum_filters:
      formal_charge: 2.0
      lewis_score: 0.0
      ring_filter: false
    react_atoms:
    - 0
    - 1
    - 2
    - 3
  initial_structure:
    mode: species
    source: O=CCO
    type: smiles
  job_manager:
    container: docker
    max_active_jobs: 4
    scheduler: local
  output: HAA_depth1.pkl
  status: STATUS.json
  verbose: true
ll_path:
  conf_gen:
    charge: 0
    lot: gfn2
    n_cpus: 2
    n_unpaired_electrons: 0
    software: crest
  method: init_rxn_path
  ts_guess:
    bias_lot: uff
    charge: 0
    gsm_lot: xtb
    joint_opt: dual
    multiplicity: 1
    n_conf: 3
    n_cpus: 2
    software: pysisyphus
ll_refine:
  initial_geom:
    product:
      label: conf_gen
      lot: gfn2
      software: crest
    reactant:
      label: conf_gen
      lot: gfn2
      software: crest
    transition_state:
      label: ts_guess
      lot: xtb
      software: pysisyphus
  irc_val:
    charge: 0
    conv_thresh: gau
    lot: xtb
    max_cycles: 100
    multiplicity: 1
    n_cpus: 2
    software: pysisyphus
  method: refine_rxn_path
  rp_opt:
    charge: 0
    hessian_recalc: 3
    lot: xtb
    max_cycles: 100
    multiplicity: 1
    n_cpus: 2
    software: pysisyphus
  ts_opt:
    charge: 0
    conv_thresh: gau
    hessian_recalc: 3
    lot: xtb
    max_cycles: 100
    multiplicity: 1
    n_cpus: 2
    software: pysisyphus
stages:
- egat
- ll_path
- ll_refine

