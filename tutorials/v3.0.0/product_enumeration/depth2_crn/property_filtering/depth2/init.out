        threshold: 55.0
        type: barrier
      separate_prods: true
  initial_structure:
    mode: reaction
    source: ../depth1/3HP_depth1.pkl
    type: yarp_pickle
  job_manager:
    container: apptainer
    max_active_jobs: 100
    queue: long
    scheduler: sge
  output: 3HP_depth2.pkl
  status: STATUS.json
  verbose: true
stages:
- egat

