egat:
  mem_per_cpu: 1000
  method: ml_rxn_prop
  model: egat_rgd1
  n_cpus: 8
initialize:
  enumeration:
    mode: concerted
    n_break: 2
    n_form: 2
    post_enum_filters:
      formal_charge: 2.0
      lewis_score: 0.0
      ring_filter: false
    react_atoms:
    - 0
    - 1
    - 2
    - 3
  initial_structure:
    mode: species
    source: '[O:0]=[C:1]([C:2]([O:3][H:7])([H:5])[H:6])[H:4]'
    type: smiles
  job_manager:
    container: apptainer
    max_active_jobs: 100
    queue: long
    scheduler: sge
  output: HAA_depth1.pkl
  status: STATUS.json
  verbose: true
ll_path:
  conf_gen:
    charge: 0
    lot: gfn2
    mem_per_cpu: 4000
    n_cpus: 2
    n_unpaired_electrons: 0
    software: crest
  method: init_rxn_path
  ts_guess:
    bias_lot: uff
    charge: 0
    gsm_lot: xtb
    joint_opt: dual
    mem_per_cpu: 4000
    multiplicity: 1
    n_conf: 3
    n_cpus: 2
    software: pysisyphus
stages:
- egat
- ll_path

